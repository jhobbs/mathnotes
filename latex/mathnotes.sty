% mathnotes.sty — LaTeX support for mathnotes content files.
% Any content/*.tex file written as a standalone document compiles with:
%   TEXINPUTS=<repo>/latex: pdflatex <file>.tex
\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{mathnotes}[2026/07/07 Mathnotes content dialect]

\RequirePackage{amsmath}
\RequirePackage{amssymb}
\RequirePackage{amsthm}
\RequirePackage[hidelinks]{hyperref}
% Code listings: \begin{lstlisting}[language=Python] (site: fenced code block)
\RequirePackage{listings}
% Images: \includegraphics[alt={...}, title={...}]{path}. The site renders
% alt text and title tooltips; for PDF both are metadata-only, so accept and
% ignore them regardless of the graphicx version's native key support.
\RequirePackage{graphicx}
\define@key{Gin}{alt}{}
\define@key{Gin}{title}{}
% pdflatex cannot fetch remote images; render a placeholder box instead of
% erroring so pages with web images still compile
\RequirePackage{xstring}
\let\mathnotes@includegraphics\includegraphics
\renewcommand{\includegraphics}[2][]{%
  \IfBeginWith{#2}{http}{\fbox{\texttt{[web image]}}}{%
    \mathnotes@includegraphics[#1]{#2}}%
}

% Site metadata commands (\title is standard LaTeX; these are no-ops in PDF).
% \renewcommand for \description: the kernel defines it as part of the
% description list environment, which the dialect does not use
\renewcommand{\description}[1]{}
\newcommand{\slug}[1]{}
% Page-level source citation: \source{title={...}, author={...}, type=book, ...}
% Rendered by the site's sources footer and bibliography; no-op in PDF
\newcommand{\source}[1]{}
% Clears the site's block-attachment anchor; does nothing in PDF
\newcommand{\detach}{}

% Notation declarations: \notation{\integers}{\mathbb{Z}} inside a block
% declares the macro site-wide (the site cross-references every use back to
% the declaring block). For PDF: define the macro if the generated package
% below hasn't already, and typeset the annotation inline.
\IfFileExists{mathnotes-notation.sty}{\RequirePackage{mathnotes-notation}}{}
\NewDocumentCommand{\notation}{m m}{%
  \providecommand{#1}{#2}\emph{(notation: \ensuremath{#1})} %
}

% Definition synonyms (site: index aliases + "(also: ...)" in the header)
\newcommand{\synonyms}[1]{\emph{(also: #1)} }
% Block tags (site: header chips; no-op in PDF)
\newcommand{\tags}[1]{}

% Block reference: \dref{label} or \dref[custom text]{label}
\NewDocumentCommand{\dref}{o m}{%
  \IfNoValueTF{#1}{\hyperref[#2]{#2}}{\hyperref[#2]{#1}}%
}
% Shorthand: \@{label} or \@[custom text]{label}, same as \dref.
% (The kernel's \@ only adjusts sentence spacing, unused in this prose.)
\RenewDocumentCommand{\@}{o m}{%
  \IfNoValueTF{#1}{\dref{#2}}{\dref[#1]{#2}}%
}
% Page link: \pagelink{slug} or \pagelink[text]{slug}
\NewDocumentCommand{\pagelink}{o m}{%
  \IfNoValueTF{#1}{\texttt{#2}}{#1}%
}
% Interactive demo placeholder
\newcommand{\includedemo}[1]{\begin{quote}\emph{[Interactive demo: #1]}\end{quote}}
% Transclude a block: the site embeds the target block's full content here.
% In PDF output it degrades to a pointer.
\NewDocumentCommand{\dembed}{m}{\begin{quote}\emph{[Embedded: \hyperref[#1]{#1}]}\end{quote}}

% Math macros shared with the site: mathjax-init.ts parses the section
% between the BEGIN/END MATH MACROS markers at build time, so this file is
% the single source of truth. Only simple one-line
% \newcommand/\renewcommand{\name}[n]{expansion} definitions belong inside
% the markers.
% BEGIN MATH MACROS
\renewcommand{\vec}[1]{\mathbf{#1}}
\renewcommand{\Re}{\operatorname{Re}}
\renewcommand{\Im}{\operatorname{Im}}
\renewcommand{\div}{\operatorname{div}}
\newcommand{\diam}{\operatorname{diam}}
\newcommand{\curl}{\operatorname{curl}}
\newcommand{\grad}{\operatorname{grad}}
\newcommand{\Arg}{\operatorname{Arg}}
\newcommand{\Log}{\operatorname{Log}}
\newcommand{\Span}{\operatorname{Span}}
\newcommand{\Cov}{\operatorname{Cov}}
\newcommand{\proj}{\operatorname{proj}}
\newcommand{\comp}{\operatorname{comp}}
\newcommand{\orth}{\operatorname{orth}}
\newcommand{\norm}{\operatorname{norm}}
\newcommand{\ord}{\operatorname{ord}}
\newcommand{\sech}{\operatorname{sech}}
\newcommand{\csch}{\operatorname{csch}}
\newcommand{\Arctan}{\operatorname{Arctan}}
\newcommand{\tr}[1]{\operatorname{tr}{#1}}
\newcommand{\Res}{\operatorname*{Res}}
\newcommand{\closure}[1]{\overline{#1}}
\newcommand{\degree}{^\circ}
% END MATH MACROS

% MathJax-isms: \require{ext} loads a MathJax extension client-side (no-op
% here); cancel provides the \cancel MathJax offers via \require{cancel}
\newcommand{\require}[1]{}
\RequirePackage{cancel}
% Unicode characters MathJax renders natively but pdflatex needs mappings for
\DeclareUnicodeCharacter{2248}{\ensuremath{\approx}}

% Theorem environments matching the site's block types (amsthm's proof
% environment covers proofs)
\theoremstyle{plain}
\newtheorem{theorem}{Theorem}
\newtheorem{lemma}{Lemma}
\newtheorem{proposition}{Proposition}
\newtheorem{corollary}{Corollary}
\newtheorem{axiom}{Axiom}
\theoremstyle{definition}
\newtheorem{definition}{Definition}
\newtheorem{example}{Example}
\newtheorem{exercise}{Exercise}
\newtheorem{solution}{Solution}
\theoremstyle{remark}
\newtheorem{remark}{Remark}
\newtheorem{note}{Note}
\newtheorem{intuition}{Intuition}
